# ─────────────────────────────────────────────────────────────────────────────
# منصة استخبارات الطيران — Flight Intelligence Platform
# .env.example — انسخ هذا الملف إلى .env وعدّل القيم
# ─────────────────────────────────────────────────────────────────────────────

# ── 🔑 FR24 API (إلزامي / REQUIRED) ─────────────────────────────────────────
# احصل على مفتاحك من: https://fr24api.flightradar24.com
FR24_API_KEY=your_fr24_api_key_here
FR24_BASE_URL=https://fr24api.flightradar24.com

# ── 🗄️ PostgreSQL ──────────────────────────────────────────────────────────
POSTGRES_USER=flightuser
POSTGRES_PASSWORD=flightpass
POSTGRES_DB=flightdb
POSTGRES_PORT=5432
DATABASE_URL=postgresql://flightuser:flightpass@postgres:5432/flightdb

# ── 📨 Redis ────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

# ── 🛡️ Application Security ─────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-string-min-32-chars
ENVIRONMENT=production

# ── 🌍 المناطق النشطة (Active Regions) ─────────────────────────────────────
# القيم المتاحة: middle_east | north_africa | central_asia | east_africa | south_asia
ACTIVE_REGIONS=middle_east,north_africa,central_asia

# ── 🗑️ الاحتفاظ بالبيانات (Data Retention) ──────────────────────────────────
# عدد الأيام قبل حذف البيانات القديمة. 0 = احتفاظ دائم.
DATA_RETENTION_DAYS=30

# ── ⚙️ إعدادات الاستيعاب (Ingestion Settings) ────────────────────────────────
# وقت الانتظار بين طلبات FR24 API (ثانية)
INGESTION_DELAY_SECONDS=10

# ── 🌐 المنافذ (Ports) ──────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=80
