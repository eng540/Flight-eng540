# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env.worker and fill in your Railway service URLs
# Get these from Railway Dashboard → Service → Variables / Connect
# ═══════════════════════════════════════════════════════════════════════════════

# From Railway: Redis service → Connect → Public URL
REDIS_URL=redis://default:PASSWORD@monorail.proxy.rlwy.net:PORT

# From Railway: PostgreSQL service → Connect → Public URL
DATABASE_URL=postgresql://postgres:PASSWORD@monorail.proxy.rlwy.net:PORT/railway

# OpenSky credentials (optional but highly recommended – increases rate limits)
OPENSKY_USERNAME=your_opensky_username
OPENSKY_PASSWORD=your_opensky_password

# Force a specific HTTP backend (optional)
# Options: curl | requests | httpx
# curl is recommended for residential IPs (best compatibility)
OPENSKY_FORCE_BACKEND=curl

# Regions to ingest periodically (comma-separated)
ACTIVE_REGIONS=middle_east,north_africa,central_asia

# Keep all historical data forever
DATA_RETENTION_DAYS=0
