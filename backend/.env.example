# Database (Railway injects DATABASE_URL automatically)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/flight_intelligence

# Redis (Railway injects REDIS_URL automatically)
REDIS_URL=redis://localhost:6379/0

# OpenSky API – leave blank for anonymous access (rate-limited)
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# App
APP_NAME=Flight Intelligence API
DEBUG=false
SECRET_KEY=change-me-in-production
ENVIRONMENT=production

# Ingestion settings
INGESTION_DELAY_SECONDS=10
INGESTION_MAX_RETRIES=3

# 0 = keep all historical data forever (recommended)
DATA_RETENTION_DAYS=0

# Comma-separated active region keys for periodic ingestion
ACTIVE_REGIONS=middle_east,north_africa,central_asia
